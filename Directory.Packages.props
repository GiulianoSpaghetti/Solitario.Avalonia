    <PackageVersion Include="Splat" Version="19.4.1" />
    <PackageVersion Include="System.Drawing.Common" Version="10.0.8" />
    <PackageVersion Include="Tmds.DBus" Version="0.94.2" />
    <PackageVersion Include="tmds.dbus.protocol" Version="0.94.2" />
    <PackageVersion Include="WixSharp_wix4" Version="2.14.0" />
