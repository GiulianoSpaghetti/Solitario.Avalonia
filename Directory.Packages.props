    <PackageVersion Include="DesktopNotifications.FreeDesktop" Version="1.3.1" />
    <PackageVersion Include="DesktopNotifications.Windows" Version="1.3.1" />
    <PackageVersion Include="HarfBuzzSharp" Version="14.2.1" />
    <PackageVersion Include="HarfBuzzSharp.NativeAssets.Linux" Version="14.2.1" />
    <PackageVersion Include="HarfBuzzSharp.NativeAssets.MacOS" Version="14.2.1" />
    <PackageVersion Include="HarfBuzzSharp.NativeAssets.WebAssembly" Version="14.2.1" />
    <PackageVersion Include="HarfBuzzSharp.NativeAssets.Win32" Version="14.2.1" />
    <PackageVersion Include="ReactiveUI" Version="23.2.28" />
